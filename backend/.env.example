# ============================================================
# Lovedogs 360 — Backend Environment Variables
# ============================================================
# Copy this file to ".env" and fill in all values below.
# IMPORTANT: Never commit the real .env file to Git.
#
# For deployed environments, set these in your host's secret manager
# instead of committing a .env file.
# ============================================================

# --- Database (Supabase Postgres) ---
# Preferred for production/staging. Use the pooled Supabase connection string
# from Supabase > Project Settings > Database > Connection string.
# Example shape:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<supabase-pooler-host>:6543/postgres?sslmode=require

# Optional local Docker fallback when DATABASE_URL is not set.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_secure_password
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=lovedogs

# --- JWT / Authentication ---
# Generate a secure random key (min 64 characters):
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your_super_secret_key_min_64_chars_change_me_in_production_xxxxxxxxxxxxx
ALGORITHM=HS256

# Access token expiration time in minutes (default: 8 days = 11520 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# --- Google OAuth ---
# Get these from: https://console.cloud.google.com/
#   > APIs & Services > Credentials > OAuth 2.0 Client IDs
#
# The Web Client ID used by frontend web browser
GOOGLE_CLIENT_ID=616203224372-756q5k5ujlqnaaekeo9pgb2pqai3ussf.apps.googleusercontent.com

# The iOS Client ID used by native iOS app
GOOGLE_IOS_CLIENT_ID=616203224372-o8137t06ph20itjsfqvec0envtllto8j.apps.googleusercontent.com

# The Android Client ID used by native Android app
GOOGLE_ANDROID_CLIENT_ID=your_android_oauth_client_id.apps.googleusercontent.com

# Server-side OAuth secret. Never expose this in frontend EXPO_PUBLIC_ variables.
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Pesapal Payments ---
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
PESAPAL_ENV=live
PESAPAL_CALLBACK_URL=https://your-api-domain.example.com/pesapal/callback
PESAPAL_IPN_URL=https://your-api-domain.example.com/pesapal/ipn

# --- Supabase Service Configuration ---
# Server-side only. Never expose the service role key to the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# --- System Emails / Password Reset ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
FRONTEND_URL=https://lovedogs360.com

# --- Push Notifications ---
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
