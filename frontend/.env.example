# ============================================================
# Lovedogs 360 — Frontend Environment Variables
# ============================================================
# Copy this file to ".env" and fill in all values below.
# IMPORTANT: Never commit the real .env file to Git.
# All variables prefixed with EXPO_PUBLIC_ are bundled into
# the client-side web/app build and are visible to end users.
# ============================================================

# --- Supabase-backed API ---
# REQUIRED for deployed/native builds.
# Phase 1: point this to the backend API that uses Supabase Postgres.
# Phase 2: point this to a Supabase Edge Function router, for example:
# https://<project-ref>.functions.supabase.co/api
EXPO_PUBLIC_API_URL=https://your-api-domain.example.com

# --- Supabase Project ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# --- Supabase Storage Buckets ---
EXPO_PUBLIC_SUPABASE_PET_IDENTITY_BUCKET=pet-identity
EXPO_PUBLIC_SUPABASE_CASE_EVIDENCE_BUCKET=case-evidence
EXPO_PUBLIC_SUPABASE_SERVICE_IMAGES_BUCKET=service-images
EXPO_PUBLIC_SUPABASE_EVENT_IMAGES_BUCKET=event-images
EXPO_PUBLIC_SUPABASE_SUPPORT_ATTACHMENTS_BUCKET=support-attachments

# --- Google OAuth (Sign in with Google) ---
# Get these from: https://console.cloud.google.com/
#   > APIs & Services > Credentials > OAuth 2.0 Client IDs
#
# Web Client ID — used when the app runs in the browser
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=616203224372-756q5k5ujlqnaaekeo9pgb2pqai3ussf.apps.googleusercontent.com
#
# iOS Client ID — used in the native iOS app
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=616203224372-o8137t06ph20itjsfqvec0envtllto8j.apps.googleusercontent.com

# Android Client ID - required for Google login in the native Android app.
# Create it in Google Cloud Console using package lovedogs360.co.ke and the app SHA-1 fingerprint.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_oauth_client_id.apps.googleusercontent.com

# Must match an Authorized redirect URI in the Google Web OAuth client.
EXPO_PUBLIC_GOOGLE_REDIRECT_PATH=auth/google

# Optional: set this when Google reports an exact redirect_uri mismatch for web.
# Example: https://lovedogs360.com/auth/google
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=
