# ==================================
# Lovedogs 360 Backend Configuration
# ==================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_db
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
FRONTEND_URL=https://lovedogs360.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Password reset email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=notifications@example.com

# Pesapal (Payment Gateway)
PESAPAL_CONSUMER_KEY=your_pesapal_key
PESAPAL_CONSUMER_SECRET=your_pesapal_secret
PESAPAL_ENV=live
PESAPAL_CALLBACK_URL=https://api.lovedogs360.com/pesapal/callback
PESAPAL_IPN_URL=https://api.lovedogs360.com/pesapal/ipn

# Supabase
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
