# ==================================
# Lovedogs 360 Backend Configuration
# ==================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_db
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
FRONTEND_URL=https://lovedogs360.com

# Bootstrap admin account
# Set these in Railway to create/update one admin user on backend startup.
ADMIN_EMAIL=admin@lovedogs360.com
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_ADMIN_PASSWORD
ADMIN_NAME=Lovedogs360 Admin

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Password reset email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=notifications@example.com
# Keep true for port 587. Set SMTP_USE_SSL=true if your provider requires port 465.
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10
# Optional but recommended on Railway/production because it sends over HTTPS instead of SMTP ports.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@lovedogs360.com

# Pesapal (Payment Gateway)
PESAPAL_CONSUMER_KEY=your_pesapal_key
PESAPAL_CONSUMER_SECRET=your_pesapal_secret
PESAPAL_ENV=live
PESAPAL_CALLBACK_URL=https://api.lovedogs360.com/pesapal/callback
PESAPAL_IPN_URL=https://api.lovedogs360.com/pesapal/ipn

# Supabase
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Expo frontend public config
EXPO_PUBLIC_API_URL=https://hunter-production-0341.up.railway.app
EXPO_PUBLIC_SUPABASE_URL=https://your_project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id
EXPO_PUBLIC_GOOGLE_REDIRECT_PATH=auth/google

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
